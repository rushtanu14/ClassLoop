{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": ".test-build",
    "rootDir": "."
  },
  "include": ["src/data.ts", "src/types.ts", "tests/**/*.ts"]
}
