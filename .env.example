# Copy this file to .env.local. Do not commit .env.local.

# Free-first recommendation:
# - Use transcript paste/upload with no credentials by default.
# - For email, create/use a Gmail account you own, such as classloop.noreply@gmail.com.
# - For Classroom/LMS, connect only to accounts the teacher/school already has.
# - For speech-to-text, prefer a local/self-hosted endpoint. OpenAI is optional and paid.

# Generic SMTP
# CLASSLOOP_SMTP_HOST=smtp.example.com
# CLASSLOOP_SMTP_PORT=587
# CLASSLOOP_SMTP_SECURE=false
# CLASSLOOP_SMTP_USER=teacher@example.com
# CLASSLOOP_SMTP_PASS=replace-me
# CLASSLOOP_SMTP_FROM=teacher@example.com
# CLASSLOOP_SMTP_PROVIDER=SMTP

# Optional centralized sender. Use this for a no-reply-like mailbox you own.
# Replies can still route to a teacher or support inbox with CLASSLOOP_REPLY_TO.
# CLASSLOOP_NO_REPLY_EMAIL=classloop.noreply@gmail.com
# CLASSLOOP_NO_REPLY_NAME=ClassLoop
# CLASSLOOP_REPLY_TO=teacher@example.com

# Gmail SMTP alternative. Use a free Gmail account you own plus an app password, not your normal password.
# CLASSLOOP_GMAIL_USER=classloop.noreply@gmail.com
# CLASSLOOP_GMAIL_APP_PASSWORD=replace-me
# CLASSLOOP_GMAIL_FROM=classloop.noreply@gmail.com

# Google Classroom OAuth. Free-first: use only an existing teacher/school Classroom account.
# CLASSLOOP_GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
# CLASSLOOP_GOOGLE_CLIENT_SECRET=replace-me
# Optional. If unset, ClassLoop uses its local desktop server callback URL.
# CLASSLOOP_GOOGLE_REDIRECT_URI=http://127.0.0.1:PORT/api/google-classroom/callback

# LMS. Canvas works directly with a base URL and access token if your school already has Canvas.
# CLASSLOOP_LMS_PROVIDER=canvas
# CLASSLOOP_LMS_BASE_URL=https://school.instructure.com
# CLASSLOOP_LMS_TOKEN=replace-me

# Generic LMS webhook alternative. ClassLoop POSTs session JSON here.
# Free-first option: point this at a self-hosted Moodle/school middleware service.
# CLASSLOOP_LMS_POST_URL=https://example.edu/classloop/recaps

# Speech-to-text for audio recording and background call capture.
# Free-first option: point ClassLoop at a local/self-hosted transcription service.
# CLASSLOOP_TRANSCRIBE_URL=http://127.0.0.1:9000/transcribe
# CLASSLOOP_TRANSCRIBE_TOKEN=

# Optional paid option: OpenAI /v1/audio/transcriptions.
# OPENAI_API_KEY=sk-...
# CLASSLOOP_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Alternative: send the recorded audio JSON payload to your own transcription service.
# CLASSLOOP_TRANSCRIBE_URL=https://example.edu/classloop/transcribe
# CLASSLOOP_TRANSCRIBE_TOKEN=replace-me
