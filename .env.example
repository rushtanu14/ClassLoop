# Copy this file to .env.local. Do not commit .env.local.

# Free-first recommendation:
# - Use transcript paste/upload with no credentials by default.
# - For email, create/use a Gmail account you own, such as relay.noreply@gmail.com.
# - Paid API-key or external LMS/Classroom posting features are intentionally not configured here.
# - Live capture uses free browser microphone/tab capture and speech recognition when available; transcript paste/upload remains the reliable free path.

# Generic SMTP
# RELAY_SMTP_HOST=smtp.example.com
# RELAY_SMTP_PORT=587
# RELAY_SMTP_SECURE=false
# RELAY_SMTP_USER=teacher@example.com
# RELAY_SMTP_PASS=replace-me
# RELAY_SMTP_FROM=teacher@example.com
# RELAY_SMTP_PROVIDER=SMTP

# Optional centralized sender. Use this for a no-reply-like mailbox you own.
# Replies can still route to a teacher or support inbox with RELAY_REPLY_TO.
# RELAY_NO_REPLY_EMAIL=relay.noreply@gmail.com
# RELAY_NO_REPLY_NAME=Relay
# RELAY_REPLY_TO=teacher@example.com

# Gmail SMTP alternative. Use a free Gmail account you own plus an app password, not your normal password.
# RELAY_GMAIL_USER=relay.noreply@gmail.com
# RELAY_GMAIL_APP_PASSWORD=replace-me
# RELAY_GMAIL_FROM=relay.noreply@gmail.com
# RELAY_FEEDBACK_NOTIFY_EMAIL=rushil@example.com

# Hosted web backend. Public browser keys are safe in Vite builds.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PRO_PRICE_ID=
VITE_RELAY_MAC_DOWNLOAD_URL=
VITE_RELAY_WINDOWS_DOWNLOAD_URL=
VITE_RELAY_LINUX_DOWNLOAD_URL=
VITE_RELAY_DONATE_URL=
VITE_RELAY_PRODUCT_FEEDBACK_URL=

# Server-only keys. Add these in Vercel project environment variables, not client code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
RELAY_PUBLIC_URL=
