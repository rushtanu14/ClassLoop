{
  "name": "classloop",
  "version": "0.1.0",
  "private": true,
  "description": "ClassLoop desktop and mobile-web classroom follow-up platform",
  "author": "ClassLoop <classloop.donotreply@gmail.com>",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "postinstall": "playwright install chromium",
    "dev": "vite --host 127.0.0.1",
    "start": "electron .",
    "build": "tsc && vite build && node scripts/strip-dist-trailing-whitespace.cjs",
    "test:import": "tsc -p tsconfig.test.json && node --experimental-specifier-resolution=node .test-build/tests/import-flow.test.js",
    "test:cloud": "tsc -p tsconfig.test.json && node --experimental-specifier-resolution=node .test-build/tests/cloud-sync.test.js",
    "test:entitlements": "tsc -p tsconfig.test.json && node tests/entitlement-gates.test.mjs",
    "test:security": "node scripts/security-baseline.cjs",
    "test:package:init": "node scripts/package-init-failure-smoke.cjs",
    "test:browser": "playwright test",
    "test:web": "playwright test -c playwright.web.config.ts",
    "test:desktop:state": "node scripts/smoke-desktop-state.cjs",
    "test:desktop:first-run": "node scripts/smoke-packaged-first-run.cjs",
    "test:release:distribution": "node scripts/verify-release-distribution.cjs",
    "test:manual": "node scripts/manual-qa-checklist.cjs",
    "test:manual:write": "node scripts/manual-qa-checklist.cjs --write",
    "test:all": "npm run build && npm run test:security && npm run test:package:init && npm run test:import && npm run test:cloud && npm run test:entitlements && npm run test:browser && npm run test:web && npm run test:desktop:state && npm run test:desktop:first-run && npm run test:release:distribution && npm run drill:rollback && npm run drill:incidents && npm run test:manual:write && git diff --check",
    "drill:rollback": "node scripts/drill-release-rollback.cjs",
    "drill:incidents": "node scripts/drill-incident-response.cjs",
    "drill:ops": "npm run drill:rollback && npm run drill:incidents",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac dmg zip --x64 --arm64",
    "package:win": "npm run build && electron-builder --win nsis zip --x64 --arm64",
    "package:linux": "npm run build && electron-builder --linux AppImage deb --x64 --arm64",
    "release:checksums": "node scripts/generate-release-checksums.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "lucide-react": "^0.468.0",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.classloop.app",
    "productName": "ClassLoop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "afterSign": "scripts/notarize-mac.cjs",
    "mac": {
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Education",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
