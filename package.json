{
  "name": "relay",
  "version": "0.1.0",
  "private": true,
  "description": "Relay desktop and mobile-web classroom follow-up platform",
  "author": "Relay <relay.donotreply@gmail.com>",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "postinstall": "playwright install chromium",
    "dev": "vite --host 127.0.0.1",
    "start": "electron .",
    "build": "tsc && vite build",
    "test:import": "tsc -p tsconfig.test.json && node --experimental-specifier-resolution=node .test-build/tests/import-flow.test.js",
    "test:browser": "playwright test",
    "test:web": "playwright test -c playwright.web.config.ts",
    "test:all": "npm run test:import && npm run test:browser && npm run test:web",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac dmg zip --x64 --arm64",
    "package:win": "npm run build && electron-builder --win nsis zip --x64 --arm64",
    "package:linux": "npm run build && electron-builder --linux AppImage deb --x64 --arm64"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "lucide-react": "^0.468.0",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.relay.app",
    "productName": "Relay",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Education",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
